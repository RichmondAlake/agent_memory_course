# Copy to .env (or rely on the workshop's existing ../.env / ../../.env).
# Only OPENAI_API_KEY is required.

OPENAI_API_KEY=sk-...

# LLM + embeddings — same choices as the companion notebook.
AMEM_MODEL=gpt-5.5
AMEM_MAX_TOKENS=1024
AMEM_EMBED_MODEL=text-embedding-3-small
AMEM_EMBED_DIMENSIONS=256

# Oracle AI Database (optional). If unset/unreachable, memorizz uses its
# FileSystemProvider (FAISS) instead — the app still runs fully. Set
# ORACLE_ENABLED=0 to skip the connection attempt entirely.
ORACLE_ENABLED=1
ORACLE_USER=VECTOR
ORACLE_PASSWORD=VectorPwd_2025
ORACLE_DSN=localhost:1521/FREEPDB1

# Where the FileSystemProvider fallback stores its data (default: ~/.memorizz_appbook)
# AMEM_FS_ROOT=~/.memorizz_appbook
