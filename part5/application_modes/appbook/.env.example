# Copy to .env (or rely on the course's existing ../.env / ../../.env).
# ANTHROPIC_API_KEY is required. The rest unlock more of the demo.

# Required — the only key the app needs. Runs every mode's LLM work AND OAMP's
# extraction/summary helper. No OpenAI key anywhere.
ANTHROPIC_API_KEY=sk-ant-...
APPMODES_MODEL=claude-opus-4-8
APPMODES_MAX_TOKENS=1024

# Oracle AI Agent Memory: local open-source embeddings (nomic via fastembed —
# no key, no network) + Claude Sonnet 4.6 as the extraction/summary helper.
APPMODES_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
APPMODES_EXTRACT_MODEL=anthropic/claude-sonnet-4-6

# Web search for the Deep Research mode (optional — degrades to model-only).
TAVILY_API_KEY=tvly-...

# Oracle AI Database (optional). If unset/unreachable, memory falls back to the
# in-process store. Set ORACLE_ENABLED=0 to skip the connection attempt.
ORACLE_ENABLED=1
ORACLE_USER=VECTOR
ORACLE_PASSWORD=VectorPwd_2025
ORACLE_DSN=localhost:1521/FREEPDB1
