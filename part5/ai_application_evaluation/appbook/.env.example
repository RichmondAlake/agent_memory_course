# Copy to .env and fill in. Only ANTHROPIC_API_KEY is required.

# Required — the model under test AND the LLM-as-judge (Claude Opus 4.8).
ANTHROPIC_API_KEY=sk-ant-...

# Optional — the LangSmith evaluation platform. With it set, every evaluation also
# uploads as a versioned, comparable experiment at https://smith.langchain.com.
# Without it, the app still computes every metric locally.
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=ai-maturity-evaluation

# Optional — Oracle AI Database. If omitted/unreachable, retrieval falls back to in-memory NumPy.
ORACLE_ENABLED=1
ORACLE_USER=VECTOR
ORACLE_PASSWORD=VectorPwd_2025
ORACLE_DSN=localhost:1521/FREEPDB1

# Optional tuning.
# AIEVAL_MODEL=claude-opus-4-8
# AIEVAL_BEIR_QUERIES=50
