# Copy to .env (or reuse the .env in the notebook folder one level up).
# Everything here is OPTIONAL:
#  • The substrate comparison + ACID benchmark run with NO key (embeddings are local).
#  • ANTHROPIC_API_KEY only powers the optional "answer from retrieved context" payoff.
#  • If Oracle is unreachable, the DB substrate falls back to an in-memory NumPy index.

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# Local open-source embeddings (torch-free, fastembed). Matches the notebook.
SUBSTRATE_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5

# Oracle AI Database (local Free container).
ORACLE_ENABLED=1
ORACLE_USER=VECTOR
ORACLE_PASSWORD=VectorPwd_2025
ORACLE_DSN=127.0.0.1:1521/FREEPDB1
